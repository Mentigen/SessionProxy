# PostgreSQL
POSTGRES_DB=sessionproxy
POSTGRES_USER=sessionproxy
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

# Test database for Seqwall (same cluster, separate DB)
TEST_POSTGRES_DB=sessionproxy_test

# Leave empty to apply all migrations
MIGRATION_VERSION=

# Environment: development | staging | prod
APP_ENV=development

# Seeding multiplier
SEED_COUNT=10

POSTGRES_EXPORTER_USER=exporter
POSTGRES_EXPORTER_PASSWORD=exporter_secret

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_PORT=3000

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

BUCKET_BACKUP_NAME=pg-backups
BACKUP_INTERVAL=0 2 * * *
BACKUP_RETENTION_COUNT=7

# HA (Patroni / etcd / HAProxy) - profile: ha
REPLICATION_PASSWORD=replication_secret
PATRONI_SUPERUSER_PASSWORD=patroni_super_secret
HA_PORT=5433
HA_STATS_PORT=7000

# BI pipeline (Debezium + Kafka + ClickHouse + Metabase) - profile: bi
METABASE_DB_PASSWORD=metabase_db_secret
METABASE_PORT=3030

# Application (Go server: proxy data plane + REST/gRPC/webui control plane) - profile: app
HTTP_PORT=8080
GRPC_PORT=9090
DEBUG_PORT=6060
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
# generate with: openssl rand -base64 32
ENCRYPTION_KEY=
# generate with: openssl rand -hex 32
JWT_SECRET=
ECHO_TARGET_PORT=8888
