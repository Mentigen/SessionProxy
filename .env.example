# PostgreSQL
POSTGRES_DB=sessionproxy
POSTGRES_USER=sessionproxy
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

# Test database for Seqwall (same cluster, separate DB)
TEST_POSTGRES_DB=sessionproxy_test

# Leave empty to apply all migrations
MIGRATION_VERSION=

# Environment: development | staging | prod
APP_ENV=development

# Seeding multiplier
SEED_COUNT=10

POSTGRES_EXPORTER_USER=exporter
POSTGRES_EXPORTER_PASSWORD=exporter_secret

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_PORT=3000

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

BUCKET_BACKUP_NAME=pg-backups
BACKUP_INTERVAL=0 2 * * *
BACKUP_RETENTION_COUNT=7
