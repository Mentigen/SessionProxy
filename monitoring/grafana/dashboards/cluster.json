{
  "uid": "ha-cluster-health",
  "title": "HA Cluster Health",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "tags": ["patroni", "etcd", "ha"],
  "panels": [
    {
      "id": 1,
      "title": "Primary node",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "name"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "patroni_master == 1",
          "legendFormat": "{{instance}}",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "title": "Postgres running (nodes)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 2 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(patroni_postgres_running)",
          "legendFormat": "running",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "title": "Cluster unlocked (no leader)",
      "type": "stat",
      "gridPos": { "x": 10, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "OK", "color": "green" }, "1": { "text": "UNLOCKED", "color": "red" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "max(patroni_cluster_unlocked)",
          "legendFormat": "unlocked",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "title": "etcd leader",
      "type": "stat",
      "gridPos": { "x": 14, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "follower", "color": "yellow" }, "1": { "text": "leader", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "yellow", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "etcd_server_is_leader",
          "legendFormat": "etcd leader",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "title": "Patroni role per node",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "min": 0,
          "max": 1
        }
      },
      "targets": [
        {
          "expr": "patroni_master",
          "legendFormat": "master - {{instance}}"
        },
        {
          "expr": "patroni_replica",
          "legendFormat": "replica - {{instance}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Leader WAL position (xlog)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "bytes"
        }
      },
      "targets": [
        {
          "expr": "patroni_xlog_location",
          "legendFormat": "xlog - {{instance}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "etcd health failures",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 6 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2 },
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      },
      "targets": [
        {
          "expr": "increase(etcd_server_health_failures_total[1m])",
          "legendFormat": "health failures / min"
        }
      ]
    },
    {
      "id": 8,
      "title": "Patroni failsafe / pause",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 6 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "min": 0,
          "max": 1
        }
      },
      "targets": [
        {
          "expr": "patroni_postgres_running",
          "legendFormat": "pg running - {{instance}}"
        }
      ]
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "links": []
}
